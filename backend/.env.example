# Configuración de Base de Datos
# Para despliegue local y Raspberry Pi se recomienda SQLite
# La base de datos se guardará como un archivo local en ./data
DATABASE_URL="file:./data/smartrehabbar.db"

# Configuración del Servidor
NODE_ENV="development"
PORT=5000

# CORS
# En desarrollo con Vite: http://localhost:3000
# En despliegue local unificado puede dejarse en http://localhost:5000
CORS_ORIGIN="http://localhost:3000"

# Configuración del Sistema (opcional)
WEIGHT_THRESHOLD_START=5
WEIGHT_THRESHOLD_END=3
SYNC_WINDOW_MS=3000
DISPLAY_STEPS=20
BALANCE_GOOD_PERCENT=10
BALANCE_WARNING_PERCENT=20

